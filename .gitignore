# .gitignore - local runtime outputs for OpenClaw voice wrapper work.
__pycache__/
*.py[cod]

.debugloop/runs/*
!.debugloop/runs/.gitkeep

.debugloop/queue/**/*.json

.debugloop/artifacts/**
!.debugloop/artifacts/
!.debugloop/artifacts/**/
!.debugloop/artifacts/**/.gitkeep

scripts/win/logs/

.playwright-cli/
