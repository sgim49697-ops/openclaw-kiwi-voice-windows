# approval.env.example - local-only Telegram approval settings template.

# Copy this file outside the repo or into a git-ignored local env file before use.
# Do not commit real bot tokens, chat ids, owner ids, or webhook secrets.

TELEGRAM_BOT_TOKEN=REPLACE_WITH_TELEGRAM_BOT_TOKEN
TELEGRAM_CHAT_ID=REPLACE_WITH_OWNER_CHAT_ID
TELEGRAM_APPROVAL_WEBHOOK_SECRET=REPLACE_WITH_RANDOM_LOCAL_SECRET
OPENCLAW_APPROVAL_QUEUE_ROOT=/home/user/projects/openclaw-kiwi-voice-windows/.debugloop/queue

# v7.4.1 target behavior:
# - Telegram can show pending request summaries.
# - Telegram approval must write the same approved JSON metadata as approval_queue.py.
# - Critical risk requests remain denied even if moved to approved.
