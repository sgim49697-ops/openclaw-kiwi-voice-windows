{
  "$comment": "approval-request.schema.json - queued external approval request schema.",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openclaw.local/schemas/approval-request.schema.json",
  "title": "OpenClaw External Approval Request",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "requestId",
    "createdAt",
    "source",
    "riskTier",
    "reason",
    "action",
    "params",
    "payloadHash",
    "approvalMethodsAllowed",
    "status"
  ],
  "properties": {
    "version": {
      "const": 1
    },
    "requestId": {
      "type": "string",
      "minLength": 8,
      "maxLength": 160,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:-]*$"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "source": {
      "type": "string",
      "minLength": 2,
      "maxLength": 80
    },
    "riskTier": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"]
    },
    "reason": {
      "type": "string",
      "minLength": 3,
      "maxLength": 2000
    },
    "action": {
      "type": "string",
      "enum": [
        "notify",
        "open_url_readonly",
        "open_vscode_codex_plan",
        "open_app_allowlisted",
        "run_task_recipe",
        "browser_read",
        "browser_interact"
      ]
    },
    "params": {
      "type": "object"
    },
    "payloadHash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "approvalMethodsAllowed": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "voice",
          "owner_voice",
          "telegram",
          "manual",
          "openclaw_approval",
          "github_pr_review",
          "local_file"
        ]
      }
    },
    "status": {
      "type": "string",
      "enum": ["pending", "approved", "rejected", "expired"]
    }
  }
}
