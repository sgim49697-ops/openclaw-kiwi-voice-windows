{
  "$comment": "openclaw-action-request.schema.json - approved dispatcher action request schema.",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openclaw.local/schemas/openclaw-action-request.schema.json",
  "title": "OpenClaw Approved Action Request",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "requestId",
    "source",
    "approvedByUser",
    "approvalMethod",
    "riskTier",
    "action",
    "params",
    "payloadHash"
  ],
  "properties": {
    "version": {
      "const": 1
    },
    "requestId": {
      "type": "string",
      "minLength": 8,
      "maxLength": 160,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:-]*$"
    },
    "source": {
      "type": "string",
      "minLength": 2,
      "maxLength": 80
    },
    "approvedByUser": {
      "const": true
    },
    "approvalMethod": {
      "type": "string",
      "enum": ["voice", "telegram", "manual"]
    },
    "riskTier": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"]
    },
    "action": {
      "type": "string",
      "enum": [
        "notify",
        "open_url_readonly",
        "open_vscode_codex_plan",
        "open_app_allowlisted",
        "run_task_recipe"
      ]
    },
    "params": {
      "type": "object"
    },
    "payloadHash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    }
  }
}
